---
import { careerHistory } from "../data/career";
---

<section id="career" class="py-20 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-xs tracking-[0.2em] text-black/30 uppercase mb-12">Career</h2>

    <div class="space-y-10">
      {
        careerHistory.map((entry) => (
          <div class="relative pl-6 border-l border-black/10">
            <div class="absolute left-0 top-[5px] -translate-x-1/2 w-2 h-2 rounded-full bg-accent" />
            <p class="text-xs font-mono text-accent/70 mb-1">{entry.period}</p>
            <h3 class="text-base font-semibold text-black/80 mb-0.5">
              {entry.company}
            </h3>
            <p class="text-xs text-black/40 mb-3">{entry.role}</p>
            <p class="text-sm text-black/60 leading-[1.9]">{entry.summary}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
