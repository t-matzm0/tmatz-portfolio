<section id="contact" class="py-20 px-6 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-xs tracking-[0.2em] text-black/30 uppercase mb-8">
      Contact
    </h2>
    <p class="text-sm text-black/50 mb-8">
      お仕事のご相談やお問い合わせはお気軽にどうぞ。
    </p>
    <div class="flex gap-3">
      <a
        href="mailto:contact@example.com"
        class="text-xs tracking-wider px-6 py-2.5 bg-black/85 text-white rounded hover:bg-black transition-colors"
      >
        Email
      </a>
      <a
        href="https://github.com/t-matzm0"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs tracking-wider px-6 py-2.5 border border-black/15 text-black/60 rounded hover:border-black/30 hover:text-black/80 transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
