---
import { skillCategories, industries } from "../data/skills";
---

<section id="skills" class="py-20 px-6 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-xs tracking-[0.2em] text-black/30 uppercase mb-12">Skills & Experience</h2>

    <div class="space-y-10">
      {
        skillCategories.map((category) => (
          <div>
            <h3 class="text-xs font-medium text-black/40 tracking-wider mb-4 uppercase">
              {category.name}
            </h3>
            <div class="flex flex-wrap gap-2">
              {category.tags.map((tag) => (
                <span class="text-xs px-3 py-1.5 rounded-full border border-accent/20 text-black/60 bg-accent/[0.03]">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))
      }

      <div>
        <h3 class="text-xs font-medium text-black/40 tracking-wider mb-4 uppercase">
          Industries
        </h3>
        <div class="flex flex-wrap gap-2">
          {
            industries.map((industry) => (
              <span class="text-xs px-3 py-1.5 rounded-full border border-black/10 text-black/50">
                {industry}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
