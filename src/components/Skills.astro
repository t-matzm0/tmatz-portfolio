---
import { skillCategories, industries } from "../data/skills";
---

<section id="skills" class="py-20 px-6 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-xs tracking-[0.2em] text-black/30 uppercase mb-12">Skills</h2>

    <div class="grid sm:grid-cols-2 gap-10">
      {
        skillCategories.map((category) => (
          <div>
            <h3 class="text-xs font-medium text-black/40 tracking-wider mb-5 uppercase">
              {category.name}
            </h3>
            <div class="space-y-3.5">
              {category.skills.map((skill) => (
                <div class="flex items-center justify-between">
                  <span class="text-sm text-black/60">{skill.name}</span>
                  <div class="flex gap-1">
                    {[1, 2, 3, 4, 5].map((level) => (
                      <div
                        class={`w-1.5 h-1.5 rounded-full ${
                          level <= skill.level ? "bg-accent" : "bg-black/10"
                        }`}
                      />
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16">
      <h3 class="text-xs font-medium text-black/40 tracking-wider mb-5 uppercase">
        Industries
      </h3>
      <div class="flex flex-wrap gap-2">
        {
          industries.map((industry) => (
            <span class="text-xs px-3 py-1.5 rounded-full border border-black/10 text-black/50">
              {industry}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
