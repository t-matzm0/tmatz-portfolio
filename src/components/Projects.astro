---
import { personalProjects } from "../data/projects";
---

<section id="projects" class="py-20 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-xs tracking-[0.2em] text-black/30 uppercase mb-12">
      Projects
    </h2>

    <div class="grid sm:grid-cols-2 gap-4">
      {
        personalProjects.map((project) => (
          <div class="bg-white rounded-lg p-5 border border-black/5 hover:border-black/10 transition-colors">
            <h3 class="text-sm font-medium text-black/70 mb-1.5">
              {project.title}
            </h3>
            <p class="text-xs text-black/40 leading-relaxed mb-3">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {project.tech.map((t) => (
                <span class="text-[10px] px-2 py-0.5 rounded bg-accent/[0.07] text-accent/70">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
