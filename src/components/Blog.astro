---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section id="blog" class="py-20 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-xs tracking-[0.2em] text-black/30 uppercase mb-12">Blog</h2>

    {
      posts.length === 0 ? (
        <p class="text-sm text-black/40">記事はまだありません。</p>
      ) : (
        <div class="space-y-6">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="block group">
              <p class="text-xs font-mono text-black/25 mb-1">
                {post.data.date.toLocaleDateString("ja-JP", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </p>
              <h3 class="text-sm font-medium text-black/70 group-hover:text-black transition-colors mb-1">
                {post.data.title}
              </h3>
              <p class="text-xs text-black/40">{post.data.description}</p>
            </a>
          ))}
        </div>
      )
    }

    <div class="mt-8">
      <a
        href="/blog"
        class="text-xs tracking-wider text-black/30 hover:text-black/60 transition-colors"
      >
        All posts &rarr;
      </a>
    </div>
  </div>
</section>
